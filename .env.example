# ===== Sunucu =====
PORT=4000
NODE_ENV=development

# ===== PostgreSQL =====
DATABASE_URL=postgresql://postgres:SIFREN@localhost:5432/focus_ai

# ===== JWT =====
# Güçlü rastgele anahtarlar üret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=degistir_bunu_uzun_rastgele_bir_deger
JWT_REFRESH_SECRET=degistir_bunu_baska_uzun_rastgele_bir_deger
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ===== Gmail SMTP (e-posta OTP) =====
# Gmail hesabında 2 adımlı doğrulamayı aç, sonra "Uygulama Şifresi" oluştur:
# https://myaccount.google.com/apppasswords  (16 haneli şifreyi buraya yaz, boşluksuz)
SMTP_USER=senin_mailin@gmail.com
SMTP_PASS=uygulama_sifresi_16_hane
SMTP_FROM=Focus AI <senin_mailin@gmail.com>

# ===== OTP =====
OTP_EXPIRES_MINUTES=10

# ===== Admin paneli =====
# İlk admin hesabı bu e-posta ile kayıt olduğunda otomatik admin yapılır
ADMIN_EMAIL=senin_mailin@gmail.com
# React admin panelinin adresi (CORS için)
ADMIN_ORIGIN=http://localhost:5173
